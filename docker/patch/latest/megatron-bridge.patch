+        >>> # Load model with specific settings
+        >>> model = PreTrainedCausalLM.from_pretrained(
+        ...     "gpt2",
+        ...     device="cuda:0",
+        ...     torch_dtype=torch.bfloat16,
+        ...     attn_implementation="flash_attention_2",
+        ...     load_in_8bit=True
+        ... )
