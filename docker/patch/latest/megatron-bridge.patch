+                    megatron_param="decoder.layers.*.mlp.shared_experts.linear_fc1.weight",
+                    gate="model.layers.*.mlp.shared_expert.gate_proj.weight",
+                    up="model.layers.*.mlp.shared_expert.up_proj.weight",
+                ),
