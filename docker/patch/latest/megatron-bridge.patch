+"""Qwen3.5-VL finetuning recipes.
+
+This module provides SFT and PEFT configurations for Qwen3.5-VL models:
+
+- **Dense**: 800M, 2B, 4B, 9B, 27B
+- **MoE**: 35B-A3B, 122B-A10B, 397B-A17B
+"""
+
+import torch
+
+from megatron.bridge import AutoBridge
