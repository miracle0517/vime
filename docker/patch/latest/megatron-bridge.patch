+            if non_extra:
+                print_rank_0(f"Warning: Exception during strict loading: {e}")
+                print_rank_0(f"Non-extra-state mismatched keys: {non_extra}")
+        else:
+            # Re-raise if we were already in non-strict mode
+            raise
