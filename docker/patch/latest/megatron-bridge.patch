+        if self.model_name_or_path is not None:
+            try:
+                return GenerationConfig.from_pretrained(
+                    self.model_name_or_path,
+                    trust_remote_code=self.trust_remote_code,
+                    **self.init_kwargs,
+                )
+            except Exception:
+                # Not all models have generation configs
+                pass
