+                GatedMLPMapping(
+                    megatron_param="mtp.layers.*.transformer_layer.mlp.experts.linear_fc1.weight*",
+                    gate="mtp.layers.*.mlp.experts.*.gate_proj.weight",
+                    up="mtp.layers.*.mlp.experts.*.up_proj.weight",
