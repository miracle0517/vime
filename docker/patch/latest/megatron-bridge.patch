+import sys
+from pathlib import Path
+from typing import Any, Dict, Generic, List, Optional, TypeVar, Union
+
+import torch
+from transformers import (
+    AutoConfig,
+    AutoImageProcessor,
+    AutoModelForCausalLM,
+    AutoProcessor,
+    AutoTokenizer,
+    GenerationConfig,
+    PreTrainedTokenizer,
